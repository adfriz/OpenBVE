+        /// Note: this struct uses M[r][c] naming where M11 = row 1 col 1, etc.
+        /// Added for the RealSky compute pass which needs inverse(view * projection).
+        /// </summary>
+        public static Matrix4 operator *(Matrix4 left, Matrix4 right)
+        {
+            return new Matrix4(
